<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- E6 = 90% opacity, sleek dark slate charcoal matching VinColors.BgColor -->
    <solid android:color="#E6101012" />
    
    <!-- Smooth 18dp rounded corners for modern launcher aesthetics -->
    <corners android:radius="18dp" />
    
    <!-- 26 = 15% opacity white glass border perfectly matching VinColors.GlassBorder -->
    <stroke
        android:width="1.2dp"
        android:color="#26FFFFFF" />
</shape>
